# ===================================================================
# Environment Variables for Sunbird Serve Fulfill
# Copy this file to .env and fill in your values
# ===================================================================

# Server
SERVER_PORT=8090

# Database Configuration
DB_URL=jdbc:postgresql://localhost:5432/ev-vriddhi
DB_USERNAME=postgres
DB_PASSWORD=your_password_here

# JPA / Hibernate
JPA_SHOW_SQL=false
JPA_DDL_AUTO=update

# Connection Pool
HIKARI_MAX_POOL=10
HIKARI_MIN_IDLE=5

# External Service URLs
SERVE_URL=https://serve-v1.evean.net
SERVE_NEED_URL=https://serve-v1.evean.net
SERVE_VOLUNTEERING_URL=https://serve-v1.evean.net

# Email Configuration
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_email@example.com
MAIL_PASSWORD=your_app_password_here

# CORS Configuration
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://serve-v1.evean.net

# Logging Levels (TRACE, DEBUG, INFO, WARN, ERROR)
LOG_LEVEL=INFO
LOG_LEVEL_SPRING=WARN
LOG_LEVEL_HIBERNATE=WARN
LOG_LEVEL_NETTY=WARN

# Swagger / OpenAPI (set to false to disable in production)
SPRINGDOC_ENABLED=true

# Error Reporting (set to false/never for production)
ERROR_INCLUDE_EXCEPTION=false
ERROR_INCLUDE_STACKTRACE=never
